@model List<GLMS.Web.Services.ServiceRequest>
@{
    var sid = Context.Request.Query["sid"].ToString();
    ViewData["Title"] = "Service Request";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Service Requests</h1>
        <div>
            <a asp-action="Create" asp-route-sid="@sid" class="btn btn-primary">+ New Service Request</a>
            <a asp-controller="Contracts" asp-action="Index" asp-route-sid="@sid" class="btn btn-secondary ms-2">Contracts</a>
            <a asp-action="Logout" asp-route-sid="@sid" class="btn btn-danger ms-2">Logout</a>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            No service requests found. Click "New Service Request" to create one.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var request in Model)
            {
                <div class="col-md-6 mb-3">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title">Service Request #@request.Id</h5>
                                <span class="badge @(request.Status == "Completed" ? "bg-success" : (request.Status == "Cancelled" ? "bg-danger" : (request.Status == "InProgress" ? "bg-info" : "bg-warning")))">
                                    @request.Status
                                </span>
                            </div>
                            <p class="card-text text-muted">@request.Description</p>
                            <hr />
                            <div class="row">
                                <div class="col-6">
                                    <strong>Contract:</strong><br />
                                    @(request.Contract?.ClientName ?? "N/A")
                                </div>
                                <div class="col-6">
                                    <strong>Amount (USD):</strong><br />
                                    @request.AmountUSD.ToString("C")
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-6">
                                    <strong>Amount (ZAR):</strong><br />
                                    @request.AmountZAR.ToString("C")
                                </div>
                                <div class="col-6">
                                    <strong>Created:</strong><br />
                                    @request.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")
                                </div>
                            </div>
                            <hr />
                            <a asp-action="Details" asp-route-id="@request.Id" asp-route-sid="@sid" class="btn btn-info btn-sm">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>