@model GLMS.Web.Controllers.ServiceRequestViewModel
@{
    var sid = Context.Request.Query["sid"].ToString();
    var contracts = ViewBag.Contracts as List<GLMS.Web.Services.Contract>;
    var currentRate = ViewBag.CurrentRate;
    var selectedContractId = ViewBag.SelectedContractId as int?;
    ViewData["Title"] = "Create Service Request";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Create New Service Request</h4>
                    @if (selectedContractId.HasValue && selectedContractId.Value > 0)
                    {
                        <small class="text-light">For selected contract</small>
                    }
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }

                    <form asp-action="Create" method="post">
                        <input type="hidden" name="sid" value="@sid" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="ContractId" class="form-label fw-bold">Contract *</label>
                            <select asp-for="ContractId" class="form-select" required>
                                <option value="">-- Select Contract --</option>
                                @if (contracts != null)
                                {
                                    foreach (var contract in contracts)
                                    {
                                        if (selectedContractId.HasValue && contract.Id == selectedContractId.Value)
                                        {
                                            <option value="@contract.Id" selected>@contract.ClientName - @contract.Amount.ToString("C")</option>
                                        }
                                        else
                                        {
                                            <option value="@contract.Id">@contract.ClientName - @contract.Amount.ToString("C")</option>
                                        }
                                    }
                                }
                            </select>
                            <span asp-validation-for="ContractId" class="text-danger"></span>
                            @if (contracts == null || !contracts.Any())
                            {
                                <div class="text-warning mt-1">
                                    <small>⚠️ No approved contracts available. Please approve a contract first.</small>
                                </div>
                            }
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter service request description"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="AmountUSD" class="form-label fw-bold">Amount (USD) *</label>
                            <input asp-for="AmountUSD" class="form-control" type="number" step="0.01" placeholder="0.00" required />
                            <span asp-validation-for="AmountUSD" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Exchange Rate (USD to ZAR)</label>
                            <input type="text" class="form-control" value="@currentRate.ToString("F2")" readonly disabled />
                            <small class="text-muted">Current exchange rate from API</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Amount (ZAR) - Estimated</label>
                            <input type="text" class="form-control" id="amountZAR" readonly disabled />
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Create Service Request</button>
                            <a asp-action="Index" asp-route-sid="@sid" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const usdInput = document.querySelector('#AmountUSD');
    const zarDisplay = document.querySelector('#amountZAR');
    const exchangeRate = @currentRate.ToString().Replace(",", ".");

    if (usdInput) {
        usdInput.addEventListener('input', function() {
            const usd = parseFloat(this.value) || 0;
            const zar = usd * exchangeRate;
            zarDisplay.value = zar.toFixed(2);
        });
    }
</script>