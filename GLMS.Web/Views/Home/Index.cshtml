@{
    var sid = ViewBag.SessionId as string ?? Context.Request.Query["sid"].ToString();
    ViewData["Title"] = "Dashboard";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 80px 0;
        border-radius: 20px;
        margin-bottom: 40px;
    }

    .feature-box {
        text-align: center;
        padding: 30px;
        border-radius: 15px;
        background: #f8f9fa;
        height: 100%;
        transition: all 0.3s ease;
    }

        .feature-box:hover {
            background: #e9ecef;
            transform: scale(1.02);
        }

    .feature-icon {
        font-size: 48px;
        margin-bottom: 20px;
    }

    .btn-start {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        padding: 15px 40px;
        font-size: 18px;
        font-weight: bold;
        border-radius: 50px;
        transition: all 0.3s ease;
        color: white !important;
        text-decoration: none;
    }

        .btn-start:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            color: white !important;
        }

    .quick-action {
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        color: inherit;
        display: block;
    }

        .quick-action:hover {
            background: #667eea10;
            border-left: 4px solid #667eea;
            text-decoration: none;
            color: inherit;
        }
</style>

<!-- Hero Section -->
<div class="hero-section text-center">
    <h1 class="display-4 fw-bold">Global Logistics Management System</h1>
    <p class="lead mt-3">Centralised contract management | Automated service requests | Real-time currency conversion</p>
    <a href="/Contracts/Index?sid=@sid" class="btn-start btn-lg mt-4">
        🚀 Get Started
    </a>
</div>

<!-- Quick Actions Section -->
<div class="container mt-4">
    <div class="row">
        <div class="col text-center mb-4">
            <h3>Quick Actions</h3>
            <p class="text-muted">Start managing your logistics operations</p>
        </div>
    </div>
    <div class="row">
        <div class="col-md-4 mb-3">
            <a href="/Contracts/Create?sid=@sid" style="text-decoration: none;">
                <div class="quick-action p-3 border rounded">
                    <div class="d-flex align-items-center">
                        <div class="feature-icon me-3">📄</div>
                        <div>
                            <h5 class="mb-0">Create Contract</h5>
                            <small class="text-muted">Add a new agreement with client</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4 mb-3">
            <a href="/ServiceRequests/Create?sid=@sid" style="text-decoration: none;">
                <div class="quick-action p-3 border rounded">
                    <div class="d-flex align-items-center">
                        <div class="feature-icon me-3">🚚</div>
                        <div>
                            <h5 class="mb-0">New Service Request</h5>
                            <small class="text-muted">Raise a logistics request</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-4 mb-3">
            <a href="/Contracts/Index?sid=@sid" style="text-decoration: none;">
                <div class="quick-action p-3 border rounded">
                    <div class="d-flex align-items-center">
                        <div class="feature-icon me-3">📋</div>
                        <div>
                            <h5 class="mb-0">View All Contracts</h5>
                            <small class="text-muted">Manage existing agreements</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="container mt-5">
    <div class="row">
        <div class="col text-center mb-4">
            <h3>Platform Features</h3>
            <p class="text-muted">Everything you need to manage global logistics</p>
        </div>
    </div>
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="feature-box">
                <div class="feature-icon">📑</div>
                <h5>Contract Management Hub</h5>
                <p class="text-muted">Centralised repository for all client agreements with automated status tracking.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="feature-box">
                <div class="feature-icon">✅</div>
                <h5>Smart Validation</h5>
                <p class="text-muted">Service requests only allowed against valid, active contracts.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="feature-box">
                <div class="feature-icon">💰</div>
                <h5>Live Currency Conversion</h5>
                <p class="text-muted">Real-time USD to ZAR exchange rates with auto-calculation.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="feature-box">
                <div class="feature-icon">🔍</div>
                <h5>Advanced Filtering</h5>
                <p class="text-muted">Search contracts by date range and status.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="feature-box">
                <div class="feature-icon">📎</div>
                <h5>PDF Upload & Storage</h5>
                <p class="text-muted">Upload signed agreements and download on demand.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="feature-box">
                <div class="feature-icon">🐳</div>
                <h5>Container Ready</h5>
                <p class="text-muted">Docker + Kubernetes support for enterprise scaling.</p>
            </div>
        </div>
    </div>
</div>