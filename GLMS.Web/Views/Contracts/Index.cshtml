@model List<GLMS.Web.Services.Contract>
@{
    var sid = Context.Request.Query["sid"].ToString();
    ViewData["Title"] = "Contracts";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Contract Management System</h1>
        <div>
            <a asp-action="Create" asp-route-sid="@sid" class="btn btn-primary">+ Create New Contract</a>
            <a asp-controller="ServiceRequests" asp-action="Index" asp-route-sid="@sid" class="btn btn-info ms-2">Service Requests</a>
            <a asp-action="Logout" asp-route-sid="@sid" class="btn btn-danger ms-2">Logout</a>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            No contracts found. Click "Create New Contract" to add one.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var contract in Model)
            {
                <div class="col-md-6 mb-3">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title">@contract.ClientName</h5>
                                <span class="badge @(contract.Status == "Approved" ? "bg-success" : (contract.Status == "Declined" ? "bg-danger" : "bg-warning"))">
                                    @contract.Status
                                </span>
                            </div>
                            <p class="card-text text-muted">@contract.Description</p>
                            <hr />
                            <div class="row">
                                <div class="col-6">
                                    <strong>Amount:</strong><br />
                                    @contract.Amount.ToString("C")
                                </div>
                                <div class="col-6">
                                    <strong>Created:</strong><br />
                                    @contract.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")
                                </div>
                            </div>
                            <hr />
                            <div class="d-flex gap-2 flex-wrap">
                                @if (contract.Status == "Pending")
                                {
                                    <form asp-action="Approve" method="post" style="display:inline">
                                        <input type="hidden" name="id" value="@contract.Id" />
                                        <input type="hidden" name="sid" value="@sid" />
                                        <button type="submit" class="btn btn-success btn-sm">✓ Approve</button>
                                    </form>
                                    <form asp-action="Decline" method="post" style="display:inline">
                                        <input type="hidden" name="id" value="@contract.Id" />
                                        <input type="hidden" name="sid" value="@sid" />
                                        <button type="submit" class="btn btn-danger btn-sm">✗ Decline</button>
                                    </form>
                                }
                                @if (contract.Status == "Approved")
                                {
                                    <a asp-controller="ServiceRequests"
                                       asp-action="Create"
                                       asp-route-sid="@sid"
                                       asp-route-contractId="@contract.Id"
                                       class="btn btn-info btn-sm">
                                        📝 Create Service Request
                                    </a>
                                }
                                <a asp-controller="ServiceRequests"
                                   asp-action="Details"
                                   asp-route-id="@contract.Id"
                                   asp-route-sid="@sid"
                                   class="btn btn-outline-secondary btn-sm">
                                    View Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>